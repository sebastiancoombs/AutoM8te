# Discord bot token (can share OpenClaw's bot or use a separate one)
DISCORD_BOT_TOKEN=your-discord-bot-token

# OpenAI API key with Realtime API access
OPENAI_API_KEY=sk-proj-...

# Discord voice channel to auto-join (optional, can also use !join command)
DISCORD_VOICE_CHANNEL_ID=

# Discord guild ID
DISCORD_GUILD_ID=

# Discord user ID to listen to (optional, listens to all if not set)
DISCORD_LISTEN_USER_ID=

# Swarm Manager URL
SWARM_MANAGER_URL=http://localhost:8000

# OpenAI Realtime model
OPENAI_REALTIME_MODEL=gpt-realtime

# Voice for TTS output
OPENAI_VOICE=coral
