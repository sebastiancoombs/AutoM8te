# Discord Bot Token (can share OpenClaw's bot or use a separate one)
DISCORD_BOT_TOKEN=your-discord-bot-token

# OpenAI API Key (must have Realtime API access)
OPENAI_API_KEY=sk-proj-...

# Discord Voice Channel to auto-join (optional — can also use !join command)
DISCORD_GUILD_ID=
DISCORD_VOICE_CHANNEL_ID=

# Swarm Manager URL
SWARM_MANAGER_URL=http://localhost:8000

# OpenAI Realtime model and voice
REALTIME_MODEL=gpt-realtime
REALTIME_VOICE=coral

# Allowed Discord user IDs (comma-separated, empty = allow all)
ALLOWED_USERS=

# Debug mode (logs all WebSocket events)
DEBUG=false
